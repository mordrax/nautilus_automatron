{
  "name": "nautilus-automatron",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "kill": "lsof -t -i :${VITE_PORT:-5173} -i :${NAUTILUS_PORT:-8000} | xargs kill 2>/dev/null; echo 'Ports freed'",
    "dev": "concurrently \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "cd packages/client && bun run dev",
    "dev:server": "cd packages/server && .venv/bin/uvicorn server.main:app --reload --port ${NAUTILUS_PORT:-8000}",
    "build": "cd packages/client && bun run build",
    "test:e2e": "cd packages/client && bun run test:e2e",
    "test:e2e:headed": "cd packages/client && bun run test:e2e:headed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
